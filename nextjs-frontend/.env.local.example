# ===========================================
# FRONTEND (Next.js) - copy thành .env.local
# ===========================================
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Tạo token: Strapi Admin > Settings > API Tokens > Create (Full access)
STRAPI_API_TOKEN=

# ===========================================
# STRAPI BACKEND - file strapi-backend/.env
# ===========================================
# FRONTEND_URL=http://localhost:3000

# ===========================================
# HƯỚNG DẪN CHẠY PROJECT
# ===========================================
# Terminal 1 - Strapi:
#   cd strapi-backend
#   npm run develop
#   -> Mở http://localhost:1337/admin (tạo tài khoản admin lần đầu)
#
# Terminal 2 - Next.js:
#   npm run dev
#   -> Mở http://localhost:3000
#
# Sau khi Strapi chạy lần đầu:
#   1. Dữ liệu mẫu tự động seed (destinations, tours, testimonials)
#   2. Permissions Public tự động cấu hình
#   3. Tạo API Token -> copy vào STRAPI_API_TOKEN ở .env.local
#   4. Restart Next.js dev server
