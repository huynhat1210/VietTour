# ==============================================
# VIETTOUR - FRONTEND ENVIRONMENT VARIABLES
# ==============================================
# Sao chép file này thành .env.local và điền giá trị thực tế
# Copy this file to .env.local and fill in the actual values

# URL của Strapi Backend (mặc định chạy local)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# API Token của Strapi - Lấy tại: Strapi Admin > Settings > API Tokens > Create new token
# Cấp quyền: Full access
STRAPI_API_TOKEN=your_strapi_api_token_here
